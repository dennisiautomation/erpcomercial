APP_NAME="ERP Comercial"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://erpcomercial.ia365.com.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Banco ──
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=erp_comercial
DB_USERNAME=erp_user
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_EXTERNAL_PORT=3310

# ── Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_EXTERNAL_PORT=6381

# ── Cache / Session / Queue ──
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

# ── Filesystem ──
FILESYSTEM_DISK=local

# ── Mail (ajuste quando configurar SMTP) ──
MAIL_MAILER=log

# ── Porta pública (Caddy aponta pra cá) ──
APP_PORT=8091

# ── Focus NFe: começa em homologação por segurança ──
# Cada empresa/unidade tem seu próprio token gravado em configuracoes_fiscais,
# então aqui não há token global — só o ambiente default pro seeder.
FOCUS_NFE_AMBIENTE=homologacao
